<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VNEditor.ViewModels"
        xmlns:model="using:VNEditor.Models"
        xmlns:controls="using:VNEditor.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1600" d:DesignHeight="950"
        x:Class="VNEditor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        x:Name="Root"
        Title="魔女：终末旅途 剧情编辑器"
        Width="1600"
        Height="950"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        RequestedThemeVariant="{Binding RequestedThemeVariantText}"
        Background="{Binding ThemeWindowBackground}"
        Opacity="{Binding WindowOpacity}">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid>
        <Image Source="{Binding EditorBackgroundImage}" Opacity="0.25" Stretch="UniformToFill" IsHitTestVisible="False"/>
        <Border Background="{Binding EditorBackgroundTintColorText}" Opacity="{Binding EditorBackgroundTintOpacity}" IsHitTestVisible="False"/>
        <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="280,480,*" Margin="12" ColumnSpacing="12" RowSpacing="10" TextBlock.FontSize="{Binding GlobalFontSize}">
            <Border Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Background="{Binding ThemeTopBarBackground}"
                    BorderBrush="{Binding ThemeBorderColor}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8"
                    PointerPressed="OnTopBarPointerPressed">
                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto,Auto">
                    <Border Grid.Column="0" Background="Transparent" Padding="8,0,10,0">
                        <TextBlock Text="魔女：终末旅途 剧情编辑器" VerticalAlignment="Center" Foreground="{Binding ThemeTextPrimary}" FontWeight="Bold"/>
                    </Border>
                    <Menu Grid.Column="1" Background="Transparent">
                        <MenuItem Header="文件">
                            <MenuItem Header="打开工程" Click="OnOpenProjectClicked"/>
                        </MenuItem>
                    </Menu>
                    <Button Grid.Column="3" Content="设置" Click="OnOpenSettingsClicked"/>
                    <Button Grid.Column="4" Content="—" Width="36" Click="OnMinimizeClicked"/>
                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                        <Button Content="□" Width="36" Click="OnMaxRestoreClicked"/>
                        <Button Content="✕" Width="36" Click="OnCloseClicked"/>
                    </StackPanel>
                </Grid>
            </Border>

        <TabControl Grid.Row="1" Grid.ColumnSpan="3" SelectedIndex="{Binding SelectedMainTabIndex, Mode=TwoWay}">
            <TabItem Header="场景编辑">
                <Grid Opacity="{Binding SceneTabOpacity}">
                    <Grid.RenderTransform>
                        <TranslateTransform X="{Binding SceneTabOffsetX}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:0.2"/>
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </Grid.RenderTransform>
                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                        </Transitions>
                    </Grid.Transitions>
                    <Border BorderThickness="1"
                            BorderBrush="{Binding ThemeBorderColor}"
                            Padding="10"
                            Background="{Binding ThemePanelBackground}"
                            CornerRadius="10"
                            Opacity="{Binding SceneGalleryOpacity}"
                            IsHitTestVisible="{Binding SceneGalleryHitTestVisible}">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                            </Transitions>
                        </Border.Transitions>
                        <Grid RowDefinitions="Auto,*" RowSpacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="新增场景" Command="{Binding AddSceneCommand}"/>
                                <Button Content="删除场景" Command="{Binding RemoveSceneCommand}"/>
                                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Margin="8,0,0,0" Foreground="{Binding ThemeTextPrimary}"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Scenes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="model:DialogueScene">
                                            <StackPanel Width="360" Margin="0,0,14,14" Spacing="6">
                                                <Border BorderBrush="{Binding DataContext.ThemeDialogBorder, ElementName=Root}"
                                                        BorderThickness="1"
                                                        Background="{Binding DataContext.ThemeCardBackground, ElementName=Root}"
                                                        CornerRadius="6"
                                                        PointerPressed="OnSceneCardPressed">
                                                    <Grid Width="360" Height="202">
                                                        <Image Source="{Binding GalleryBackground}" Stretch="UniformToFill"/>
                                                        <Grid VerticalAlignment="Stretch" IsVisible="{Binding GalleryUseSinglePortrait}">
                                                            <Image Source="{Binding GallerySinglePortrait}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                            <Border Background="#33000000" IsVisible="{Binding GallerySinglePortraitDim}">
                                                                <Border.OpacityMask>
                                                                    <ImageBrush Source="{Binding GallerySinglePortrait}" Stretch="Uniform"/>
                                                                </Border.OpacityMask>
                                                            </Border>
                                                        </Grid>
                                                        <Grid ColumnDefinitions="*,*" VerticalAlignment="Stretch" IsVisible="{Binding GalleryUseDualPortrait}">
                                                            <Grid Grid.Column="0" IsVisible="{Binding GalleryPortrait1Visible}">
                                                                <Image Source="{Binding GalleryPortrait1}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                                <Border Background="#33000000" IsVisible="{Binding GalleryPortrait1Dim}">
                                                                    <Border.OpacityMask>
                                                                        <ImageBrush Source="{Binding GalleryPortrait1}" Stretch="Uniform"/>
                                                                    </Border.OpacityMask>
                                                                </Border>
                                                            </Grid>
                                                            <Grid Grid.Column="1" IsVisible="{Binding GalleryPortrait2Visible}">
                                                                <Image Source="{Binding GalleryPortrait2}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                                <Border Background="#33000000" IsVisible="{Binding GalleryPortrait2Dim}">
                                                                    <Border.OpacityMask>
                                                                        <ImageBrush Source="{Binding GalleryPortrait2}" Stretch="Uniform"/>
                                                                    </Border.OpacityMask>
                                                                </Border>
                                                            </Grid>
                                                        </Grid>
                                                        <Border VerticalAlignment="Bottom"
                                                                Margin="8"
                                                                Padding="10"
                                                                Background="{Binding DataContext.ThemeDialogBackground, ElementName=Root}"
                                                                BorderBrush="{Binding DataContext.ThemeDialogBorder, ElementName=Root}"
                                                                BorderThickness="1"
                                                                CornerRadius="8">
                                                            <controls:RichDialogueTextBlock DialogueText="{Binding PreviewText}" Foreground="{Binding DataContext.ThemeTextPrimary, ElementName=Root}" TextWrapping="Wrap"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding DisplayName}" HorizontalAlignment="Center" FontWeight="Bold" Foreground="{Binding DataContext.ThemeTextPrimary, ElementName=Root}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Grid ColumnDefinitions="420,*"
                          ColumnSpacing="12"
                          Opacity="{Binding SceneDetailOpacity}"
                          IsHitTestVisible="{Binding SceneDetailHitTestVisible}">
                        <Grid.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                            </Transitions>
                        </Grid.Transitions>
                        <Border Grid.Column="0"
                                BorderThickness="1"
                                BorderBrush="{Binding ThemeBorderColor}"
                                Background="{Binding ThemePanelAltBackground}"
                                CornerRadius="10"
                                Padding="8">
                            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button Content="上一页" Command="{Binding BackToSceneGalleryCommand}"/>
                                    <Button Content="保存场景"
                                            Command="{Binding SaveSceneCommand}"
                                            CommandParameter="{Binding SelectedScene}"/>
                                    <Button Content="删除场景" Command="{Binding RemoveSceneCommand}"/>
                                    <Button Content="播放当前场景" Click="OnPlaySceneClicked" IsVisible="{Binding HasSelectedScene}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="对话行" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <Button Content="新增" Command="{Binding AddLineCommand}"/>
                                    <Button Content="复制" Command="{Binding DuplicateLineCommand}"/>
                                    <Button Content="删除" Command="{Binding RemoveLineCommand}"/>
                                </StackPanel>

                                <TextBox Grid.Row="2"
                                         Watermark="场景名"
                                         Text="{Binding SelectedScene.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                                <ListBox Grid.Row="3"
                                         Background="{Binding ThemeListBackground}"
                                         BorderBrush="{Binding ThemeBorderColor}"
                                         BorderThickness="1"
                                         ItemsSource="{Binding SelectedScene.Lines}"
                                         SelectedItem="{Binding SelectedLine}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate x:DataType="model:DialogueLine">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{Binding CsvId}" Width="60"/>
                                                <TextBlock Text="{Binding Roles}" Width="130" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Text}" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1"
                                BorderThickness="1"
                                BorderBrush="{Binding ThemeBorderColor}"
                                Background="{Binding ThemeEditorPanelBackground}"
                                CornerRadius="10"
                                Padding="8">
                        <Grid RowDefinitions="2*,3*" RowSpacing="10">
                            <Viewbox Stretch="Uniform" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                <Border Width="1600" Height="900" Background="#1E1E1E" CornerRadius="4" PointerPressed="OnPreviewPointerPressed">
                                    <Grid>
                                        <Image Source="{Binding PreviewBackground}" Stretch="UniformToFill"/>
                                        <Grid VerticalAlignment="Stretch" IsVisible="{Binding PreviewUseSinglePortrait}">
                                            <Image Source="{Binding PreviewSinglePortrait}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                            <Border Background="#33000000" IsVisible="{Binding PreviewSinglePortraitDim}">
                                                <Border.OpacityMask>
                                                    <ImageBrush Source="{Binding PreviewSinglePortrait}" Stretch="Uniform"/>
                                                </Border.OpacityMask>
                                            </Border>
                                        </Grid>
                                        <Grid ColumnDefinitions="*,*" VerticalAlignment="Stretch" IsVisible="{Binding PreviewUseDualPortrait}">
                                            <Grid Grid.Column="0" IsVisible="{Binding PreviewPortrait1Visible}">
                                                <Image Source="{Binding PreviewPortrait1}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                <Border Background="#33000000" IsVisible="{Binding PreviewPortrait1Dim}">
                                                    <Border.OpacityMask>
                                                        <ImageBrush Source="{Binding PreviewPortrait1}" Stretch="Uniform"/>
                                                    </Border.OpacityMask>
                                                </Border>
                                            </Grid>
                                            <Grid Grid.Column="1" IsVisible="{Binding PreviewPortrait2Visible}">
                                                <Image Source="{Binding PreviewPortrait2}" Stretch="Uniform" HorizontalAlignment="Center"/>
                                                <Border Background="#33000000" IsVisible="{Binding PreviewPortrait2Dim}">
                                                    <Border.OpacityMask>
                                                        <ImageBrush Source="{Binding PreviewPortrait2}" Stretch="Uniform"/>
                                                    </Border.OpacityMask>
                                                </Border>
                                            </Grid>
                                        </Grid>
                                        <Border VerticalAlignment="Bottom" Background="#E6191A1E" BorderBrush="#CCFFFFFF" BorderThickness="4" CornerRadius="18" Padding="24" Margin="18">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding PreviewSpeaker}" FontWeight="Bold" FontSize="44" Foreground="White"/>
                                                <controls:RichDialogueTextBlock DialogueText="{Binding PreviewText}" TextWrapping="Wrap" Foreground="White" FontSize="40"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding PreviewChoice1Visible}">
                                                    <Button Content="{Binding PreviewChoice1Text}" Command="{Binding SelectPreviewChoice1Command}" FontSize="30"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding PreviewChoice2Visible}">
                                                    <Button Content="{Binding PreviewChoice2Text}" Command="{Binding SelectPreviewChoice2Command}" FontSize="30"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding PreviewChoice3Visible}">
                                                    <Button Content="{Binding PreviewChoice3Text}" Command="{Binding SelectPreviewChoice3Command}" FontSize="30"/>
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding PreviewChoice4Visible}">
                                                    <Button Content="{Binding PreviewChoice4Text}" Command="{Binding SelectPreviewChoice4Command}" FontSize="30"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Viewbox>

                            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" Padding="0,0,14,0">
                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                      ColumnDefinitions="120,*"
                                      RowSpacing="6"
                                      ColumnSpacing="8"
                                      HorizontalAlignment="Stretch">
                                    <TextBlock Text="Id段" Grid.Row="0" Grid.Column="0"/>
                                    <TextBox Text="{Binding SelectedLine.IdPart, Mode=TwoWay}" Grid.Row="0" Grid.Column="1"/>

                                    <TextBlock Text="角色" Grid.Row="2" Grid.Column="0"/>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ComboBox Width="280"
                                                      ItemsSource="{Binding RoleOptions}"
                                                      SelectedItem="{Binding SelectedRole1Option, Mode=TwoWay}"
                                                      DisplayMemberBinding="{Binding DisplayName}"/>
                                            <CheckBox Content="非叙述者" VerticalAlignment="Center" IsChecked="{Binding SelectedRole1Muted, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ComboBox Width="280"
                                                      ItemsSource="{Binding RoleOptions}"
                                                      SelectedItem="{Binding SelectedRole2Option, Mode=TwoWay}"
                                                      DisplayMemberBinding="{Binding DisplayName}"/>
                                            <CheckBox Content="非叙述者" VerticalAlignment="Center" IsChecked="{Binding SelectedRole2Muted, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <CheckBox Content="旁白" IsChecked="{Binding SelectedLine.IsNarrator, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="事件名" Grid.Row="3" Grid.Column="0"/>
                                    <TextBox Text="{Binding SelectedLine.EventName, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                                    <TextBlock Text="选项数量" Grid.Row="4" Grid.Column="0"/>
                                    <NumericUpDown Minimum="0" Maximum="4" Value="{Binding SelectedLine.ChoiceCount, Mode=TwoWay}" Grid.Row="4" Grid.Column="1"/>

                                    <Expander Grid.Row="5" Grid.ColumnSpan="2" Header="选项" IsExpanded="True" HorizontalAlignment="Stretch">
                                        <StackPanel Spacing="6" Margin="0,6,0,0">
                                            <Expander Header="选项1" IsVisible="{Binding OptionEditor1Visible}" IsExpanded="True" HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                                                    <TextBlock Text="ChoiceScript1" Grid.Row="0" Grid.Column="0"/>
                                                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <Button Grid.Column="0" Content="编辑 ChoiceScript1" Click="OnEditChoiceScript1Clicked"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SelectedLine.ChoiceScript1}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="56"/>
                                                    </Grid>
                                                    <TextBlock Text="文本(zh)" Grid.Row="1" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText1, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                                                    <TextBlock Text="文本(en)" Grid.Row="2" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText1En, Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
                                                    <TextBlock Text="文本(ja)" Grid.Row="3" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText1Ja, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                                                </Grid>
                                            </Expander>
                                            <Expander Header="选项2" IsVisible="{Binding OptionEditor2Visible}" HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                                                    <TextBlock Text="ChoiceScript2" Grid.Row="0" Grid.Column="0"/>
                                                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <Button Grid.Column="0" Content="编辑 ChoiceScript2" Click="OnEditChoiceScript2Clicked"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SelectedLine.ChoiceScript2}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="56"/>
                                                    </Grid>
                                                    <TextBlock Text="文本(zh)" Grid.Row="1" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText2, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                                                    <TextBlock Text="文本(en)" Grid.Row="2" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText2En, Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
                                                    <TextBlock Text="文本(ja)" Grid.Row="3" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText2Ja, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                                                </Grid>
                                            </Expander>
                                            <Expander Header="选项3" IsVisible="{Binding OptionEditor3Visible}" HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                                                    <TextBlock Text="ChoiceScript3" Grid.Row="0" Grid.Column="0"/>
                                                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <Button Grid.Column="0" Content="编辑 ChoiceScript3" Click="OnEditChoiceScript3Clicked"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SelectedLine.ChoiceScript3}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="56"/>
                                                    </Grid>
                                                    <TextBlock Text="文本(zh)" Grid.Row="1" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText3, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                                                    <TextBlock Text="文本(en)" Grid.Row="2" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText3En, Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
                                                    <TextBlock Text="文本(ja)" Grid.Row="3" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText3Ja, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                                                </Grid>
                                            </Expander>
                                            <Expander Header="选项4" IsVisible="{Binding OptionEditor4Visible}" HorizontalAlignment="Stretch">
                                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                                                    <TextBlock Text="ChoiceScript4" Grid.Row="0" Grid.Column="0"/>
                                                    <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                                        <Button Grid.Column="0" Content="编辑 ChoiceScript4" Click="OnEditChoiceScript4Clicked"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding SelectedLine.ChoiceScript4}"
                                                                   VerticalAlignment="Center"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="56"/>
                                                    </Grid>
                                                    <TextBlock Text="文本(zh)" Grid.Row="1" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText4, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                                                    <TextBlock Text="文本(en)" Grid.Row="2" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText4En, Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
                                                    <TextBlock Text="文本(ja)" Grid.Row="3" Grid.Column="0"/>
                                                    <TextBox Text="{Binding SelectedLine.ChoiceText4Ja, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                                                </Grid>
                                            </Expander>
                                        </StackPanel>
                                    </Expander>

                                    <TextBlock Text="背景图(预览/元数据)" Grid.Row="6" Grid.Column="0"/>
                                    <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                        <TextBox Grid.Column="0"
                                                 IsReadOnly="True"
                                                 Text="{Binding SelectedLine.BackgroundPath, Mode=TwoWay}"/>
                                        <Button Grid.Column="1" Content="画廊选择" Click="OnOpenBackgroundGalleryClicked"/>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                            <Button Content="刷新" Command="{Binding RefreshBackgroundOptionsCommand}"/>
                                            <Button Content="清空" Click="OnClearLineBackgroundClicked"/>
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="BaseScript" Grid.Row="7" Grid.Column="0"/>
                                    <Grid Grid.Row="7" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Content="编辑 BaseScript" Click="OnEditBaseScriptClicked"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedLine.BaseScript}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="56"/>
                                    </Grid>
                                    <TextBlock Text="EndScript" Grid.Row="8" Grid.Column="0"/>
                                    <Grid Grid.Row="8" Grid.Column="1" ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                        <Button Grid.Column="0" Content="编辑 EndScript" Click="OnEditEndScriptClicked"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedLine.EndScript}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="56"/>
                                    </Grid>
                                    <Expander Grid.Row="11" Grid.ColumnSpan="2" Header="正文文本（含本地化）" IsExpanded="True" HorizontalAlignment="Stretch">
                                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="6" ColumnSpacing="8" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                                            <TextBlock Text="文本(zh)" Grid.Row="0" Grid.Column="0"/>
                                            <TextBox Text="{Binding SelectedLine.Text, Mode=TwoWay}" AcceptsReturn="True" MinHeight="100" Grid.Row="0" Grid.Column="1"/>
                                            <TextBlock Text="文本(en)" Grid.Row="1" Grid.Column="0"/>
                                            <TextBox Text="{Binding SelectedLine.TextEn, Mode=TwoWay}" AcceptsReturn="True" Grid.Row="1" Grid.Column="1"/>
                                            <TextBlock Text="文本(ja)" Grid.Row="2" Grid.Column="0"/>
                                            <TextBox Text="{Binding SelectedLine.TextJa, Mode=TwoWay}" AcceptsReturn="True" Grid.Row="2" Grid.Column="1"/>
                                        </Grid>
                                    </Expander>
                                </Grid>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="角色编辑">
                <Grid ColumnDefinitions="420,*" ColumnSpacing="12" Opacity="{Binding RoleTabOpacity}">
                    <Grid.RenderTransform>
                        <TranslateTransform X="{Binding RoleTabOffsetX}">
                            <TranslateTransform.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="X" Duration="0:0:0.2"/>
                                </Transitions>
                            </TranslateTransform.Transitions>
                        </TranslateTransform>
                    </Grid.RenderTransform>
                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                        </Transitions>
                    </Grid.Transitions>
                    <Border Grid.Column="0"
                            BorderThickness="1"
                            BorderBrush="{Binding ThemeBorderColor}"
                            Background="{Binding ThemePanelAltBackground}"
                            CornerRadius="10"
                            Padding="8">
                        <Grid RowDefinitions="Auto,*" RowSpacing="8">
                            <WrapPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBlock Text="分类" VerticalAlignment="Center" Margin="0,6,6,0"/>
                                <ComboBox Width="120"
                                          Margin="0,0,6,0"
                                          ItemsSource="{Binding RoleCategories}"
                                          SelectedItem="{Binding SelectedRoleCategory, Mode=TwoWay}"/>
                                <TextBox Width="120"
                                         Margin="0,0,6,0"
                                         Watermark="新分类"
                                         Text="{Binding NewRoleCategoryName, Mode=TwoWay}"/>
                                <Button Margin="0,0,6,0" Content="新增分类" Command="{Binding AddRoleCategoryCommand}"/>
                                <Button Margin="0,0,6,0" Content="删除分类" Command="{Binding RemoveRoleCategoryCommand}"/>
                                <Button Margin="0,0,6,0" Content="新增角色" Command="{Binding AddRoleCommand}"/>
                                <Button Margin="0,0,6,0" Content="删除角色" Command="{Binding RemoveRoleCommand}"/>
                                <Button Content="保存角色" Command="{Binding SaveRolesCommand}"/>
                            </WrapPanel>
                            <ListBox Grid.Row="1"
                                     Background="{Binding ThemeListAltBackground}"
                                     BorderBrush="{Binding ThemeBorderColor}"
                                     BorderThickness="1"
                                     ItemsSource="{Binding FilteredRoleEntries}"
                                     SelectedItem="{Binding SelectedRoleEntry}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate x:DataType="model:RoleEntry">
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1"
                            BorderThickness="1"
                            BorderBrush="{Binding ThemeBorderColor}"
                            Background="{Binding ThemeEditorPanelBackground}"
                            CornerRadius="10"
                            Padding="8">
                        <Grid ColumnDefinitions="140,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <TextBlock Text="分类" Grid.Row="0" Grid.Column="0"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding RoleCategories}"
                                      SelectedItem="{Binding SelectedRoleEntry.Category, Mode=TwoWay}"/>
                            <TextBlock Text="Id" Grid.Row="1" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.Id, Mode=TwoWay}" Grid.Row="1" Grid.Column="1"/>
                            <TextBlock Text="中文名" Grid.Row="2" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.Name, Mode=TwoWay}" Grid.Row="2" Grid.Column="1"/>
                            <TextBlock Text="Name_en" Grid.Row="3" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.NameEn, Mode=TwoWay}" Grid.Row="3" Grid.Column="1"/>
                            <TextBlock Text="Name_zh-Hant" Grid.Row="4" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.NameZhHant, Mode=TwoWay}" Grid.Row="4" Grid.Column="1"/>
                            <TextBlock Text="Name_ja" Grid.Row="5" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.NameJa, Mode=TwoWay}" Grid.Row="5" Grid.Column="1"/>
                            <TextBlock Text="Avatar路径" Grid.Row="6" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.Avatar, Mode=TwoWay}" Grid.Row="6" Grid.Column="1"/>
                            <TextBlock Text="CharacterImage路径" Grid.Row="7" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedRoleEntry.CharacterImage, Mode=TwoWay}" Grid.Row="7" Grid.Column="1"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

            <TextBlock Grid.Row="2" Grid.ColumnSpan="3" Foreground="{Binding ThemeTextMuted}"
                       Text="VNEditor for Apocalypse Journey"/>
        </Grid>

        <Border IsVisible="{Binding IsStartupUpdateChecking}"
                Background="#66000000"
                ZIndex="999">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <Grid Width="46" Height="46">
                    <Ellipse Width="42"
                             Height="42"
                             Stroke="#33FFFFFF"
                             StrokeThickness="6"/>
                    <Ellipse Width="42"
                             Height="42"
                             Stroke="#E6FFFFFF"
                             StrokeThickness="6"
                             StrokeDashArray="26,220"
                             StrokeDashOffset="{Binding StartupSpinnerDashOffset}"
                             StrokeLineCap="Round"/>
                </Grid>
                <TextBlock Text="{Binding StartupUpdateCheckingText}"
                           Foreground="{Binding ThemeTextPrimary}"
                           FontSize="16"/>
                <ProgressBar Width="320"
                             Height="10"
                             IsVisible="{Binding IsStartupUpdateDownloading}"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding StartupUpdateDownloadProgress}"/>
            </StackPanel>
        </Border>
    </Grid>

</Window>
