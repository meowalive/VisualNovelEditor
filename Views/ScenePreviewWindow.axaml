<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VNEditor.ViewModels"
        xmlns:controls="using:VNEditor.Controls"
        x:Class="VNEditor.Views.ScenePreviewWindow"
        x:DataType="vm:ScenePreviewViewModel"
        Width="1280"
        Height="720"
        SystemDecorations="Full"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        Title="{Binding WindowTitle}"
        Background="Black">
    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0"
                Background="#2A2A2A"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Padding="8"
                PointerPressed="OnTopBarPointerPressed">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Grid.Column="0" Text="{Binding WindowTitle}" VerticalAlignment="Center" Foreground="#D4D4D4" FontWeight="Bold"/>
                <Button Grid.Column="1" Content="—" Width="36" Click="OnMinimizeClicked"/>
                <Button Grid.Column="2" Content="□" Width="36" Margin="4,0,0,0" Click="OnMaxRestoreClicked"/>
                <Button Grid.Column="3" Content="✕" Width="36" Margin="4,0,0,0" Click="OnCloseClicked"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" PointerPressed="OnPreviewPointerPressed">
            <Image Source="{Binding PreviewBackground}" Stretch="UniformToFill"/>

            <Grid VerticalAlignment="Stretch" IsVisible="{Binding PreviewUseSinglePortrait}">
                <Image Source="{Binding PreviewSinglePortrait}" Stretch="Uniform" HorizontalAlignment="Center"/>
                <Border Background="#33000000" IsVisible="{Binding PreviewSinglePortraitDim}">
                    <Border.OpacityMask>
                        <ImageBrush Source="{Binding PreviewSinglePortrait}" Stretch="Uniform"/>
                    </Border.OpacityMask>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" VerticalAlignment="Stretch" IsVisible="{Binding PreviewUseDualPortrait}">
                <Grid Grid.Column="0" IsVisible="{Binding PreviewPortrait1Visible}">
                    <Image Source="{Binding PreviewPortrait1}" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <Border Background="#33000000" IsVisible="{Binding PreviewPortrait1Dim}">
                        <Border.OpacityMask>
                            <ImageBrush Source="{Binding PreviewPortrait1}" Stretch="Uniform"/>
                        </Border.OpacityMask>
                    </Border>
                </Grid>
                <Grid Grid.Column="1" IsVisible="{Binding PreviewPortrait2Visible}">
                    <Image Source="{Binding PreviewPortrait2}" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <Border Background="#33000000" IsVisible="{Binding PreviewPortrait2Dim}">
                        <Border.OpacityMask>
                            <ImageBrush Source="{Binding PreviewPortrait2}" Stretch="Uniform"/>
                        </Border.OpacityMask>
                    </Border>
                </Grid>
            </Grid>

            <Border VerticalAlignment="Bottom"
                    Background="#E6191A1E"
                    BorderBrush="#CCFFFFFF"
                    BorderThickness="3"
                    CornerRadius="14"
                    Padding="16"
                    Margin="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding PreviewSpeaker}" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <controls:RichDialogueTextBlock DialogueText="{Binding PreviewText}" Foreground="White" FontSize="24" TextWrapping="Wrap"/>

                    <StackPanel Spacing="6" Margin="0,8,0,0">
                        <Button IsVisible="{Binding PreviewChoice1Visible}" Content="{Binding PreviewChoice1Text}" Command="{Binding SelectChoice1Command}" FontSize="20"/>
                        <Button IsVisible="{Binding PreviewChoice2Visible}" Content="{Binding PreviewChoice2Text}" Command="{Binding SelectChoice2Command}" FontSize="20"/>
                        <Button IsVisible="{Binding PreviewChoice3Visible}" Content="{Binding PreviewChoice3Text}" Command="{Binding SelectChoice3Command}" FontSize="20"/>
                        <Button IsVisible="{Binding PreviewChoice4Visible}" Content="{Binding PreviewChoice4Text}" Command="{Binding SelectChoice4Command}" FontSize="20"/>
                    </StackPanel>

                    <TextBlock Text="{Binding PreviewHint}" Foreground="#CCCCCC" FontSize="16"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
